TG_BOT_TOKEN="your_telegram_bot_token"
TG_ALLOWED_CHAT_ID="your_allowed_chat_id"
# Optional second auth layer for /codex command.
# - Empty: use `/codex ...`
# - Set value: use `/codex <secret> ...`
# Recommendation: set this in .env, rotate it regularly (for example before each trip),
# and stop the worker when you are at home and can use local Codex directly.
COMMAND_SECRET=""
# Optional absolute path to codex binary (for example from `asdf which codex`).
# Leave empty to auto-detect.
CODEX_BIN=""
WORKDIR="/absolute/path/to/default/workdir"
BOT_NAME="codex-remote"
